# Server
PORT=3000
NODE_ENV=development

# Database - stores study/job metadata
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=dicom_pipeline

# Redis - background job queue for async processing
REDIS_HOST=localhost
REDIS_PORT=6379

# S3/MinIO - object storage for NIfTI volumes and STL meshes
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=dicom-artifacts
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Worker - path to python interpreter and imaging-worker CLI
WORKER_PYTHON_PATH=/path/to/imaging-worker/.venv/bin/python
WORKER_SCRIPT_PATH=../imaging-worker/src/cli.py

# Security - JWT tokens and file size limits
JWT_SECRET=change-me-in-production
UPLOAD_MAX_SIZE_MB=500
